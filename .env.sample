# cartlog configuration
#
# Copy this file to `.env.secret` (gitignored) and fill in your values.
# Two settings are required: the chosen provider's API key (e.g. ANTHROPIC_API_KEY)
# and CARTLOG_SECRET_KEY. All other settings are optional.
# Model-selection variables are prefixed CARTLOG_; provider credentials
# use each provider's own native variable name.
#
# Each value is read from the process environment first and from this file
# second: an exported environment variable always overrides the file. This is
# how the Docker setup injects configuration (compose env + .env.secret).

# ---------------------------------------------------------------------------
# Security (required)
# ---------------------------------------------------------------------------

# Required. Signs sessions and CSRF tokens. Generate with: openssl rand -hex 32
CARTLOG_SECRET_KEY=

# Send the session cookie only over HTTPS. Set false only for plain-HTTP LAN/dev.
CARTLOG_COOKIE_SECURE=true

# Session absolute lifetime and idle timeout, in days.
CARTLOG_SESSION_LIFETIME_DAYS=14
CARTLOG_SESSION_IDLE_TIMEOUT_DAYS=7

# ---------------------------------------------------------------------------
# LLM provider (required)
# ---------------------------------------------------------------------------

# cartlog selects the provider via the model id below. Supply the API key for the
# provider you choose using that provider's native variable (NOT a CARTLOG_ prefix):
#   Anthropic -> ANTHROPIC_API_KEY
#   OpenAI    -> OPENAI_API_KEY
#   Gemini    -> GEMINI_API_KEY
ANTHROPIC_API_KEY=

# Provider-prefixed model used to parse receipt images. Defaults to anthropic:claude-opus-4-8.
# Examples: openai:gpt-5.2, google:gemini-2.5-pro, anthropic:claude-sonnet-4-6,
#           openrouter:anthropic/claude-3.5-sonnet
CARTLOG_PARSE_MODEL=anthropic:claude-opus-4-8

# Provider-prefixed id for the cheap, text-only assist model used by focused secondary passes
# (category reclassification and size extraction). Needs structured output only; no vision.
# Defaults to anthropic:claude-haiku-4-5.
CARTLOG_ASSIST_MODEL=anthropic:claude-haiku-4-5

# Max times the reclassifier retries a still-uncategorized product before leaving it for
# manual review. Prevents unbounded LLM calls on products it cannot place. Defaults to 2.
CARTLOG_MAX_RECLASSIFY_ATTEMPTS=2

# Max times the size extractor retries a line with no resolvable size before leaving it as-is.
# Prevents unbounded LLM calls on genuinely size-less items (e.g. a single apple). Defaults to 2.
CARTLOG_MAX_SIZE_EXTRACT_ATTEMPTS=2

# Path to the SQLite database file. Give a plain filesystem path (e.g. /app/data.db or
# cartlog.db); the directory must already exist and the sqlite:/// prefix is added for you.
# A full SQLAlchemy URL (e.g. sqlite:///cartlog.db) is also accepted and used as-is.
CARTLOG_DATABASE_URL=cartlog.db

# Directory where ingested receipt images are copied and retained.
CARTLOG_IMAGE_STORAGE_DIR=receipt_images

# Default destination directory for `cartlog backup` when no --output is given. Must already
# exist. Leave unset to write into the current working directory. The web download (Settings ->
# Backup) always streams the archive to your browser and never writes here. Unset by default.
# CARTLOG_BACKUP_DIR=/data/backups

# Parses with confidence below this threshold are flagged needs_review
# instead of parsed. Range 0.0-1.0. Defaults to 0.7.
CARTLOG_REVIEW_CONFIDENCE_THRESHOLD=0.7

# Line-item totals may differ from the grand total by at most this fraction before
# the receipt is flagged for review. Defaults to 0.05 (5%).
CARTLOG_TOTAL_MISMATCH_TOLERANCE=0.05

# Seconds the background ingestion worker sleeps between polls when the queue is empty.
# Defaults to 2.0.
CARTLOG_WORKER_POLL_INTERVAL=2.0

# Transient-failure retry budget before a job is permanently marked 'failed'. Defaults to 3.
CARTLOG_MAX_RETRIES=3

# Base seconds for exponential retry backoff (delay = base * 2^(retry_count - 1)).
# Defaults to 30.0.
CARTLOG_RETRY_BACKOFF_BASE_SECONDS=30.0

# A job stuck in 'parsing' longer than this (e.g. a crashed worker) is re-queued by the
# reaper. Defaults to 300.0 seconds.
CARTLOG_PARSING_STALE_TIMEOUT_SECONDS=300.0

# Reject web uploads larger than this many bytes. Defaults to 10485760 (10 MiB).
CARTLOG_MAX_UPLOAD_BYTES=10485760
